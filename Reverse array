#include <iostream>
#include <algorithm>
using namespace std;
void reverseArray(int arr[], int size) {
    int left = 0, right = size - 1;
    while (left < right) swap(arr[left++], arr[right--]);
}
int main() {
    int arr[] = {1, 2, 3, 4, 5, 6};
    int size = sizeof(arr) / sizeof(arr[0]);
    reverseArray(arr, size);
    for (int i = 0; i < size; i++) cout << arr[i] << " ";
    cout << endl;
    return 0;
}

