#include <iostream>
using namespace std;
int main() {
    int arr[] = {12, 35, 1, 10, 34, 1};
    int n = sizeof(arr) / sizeof(arr[0]);
    int max1 = arr[0], max2 = -1;
    for (int i = 1; i < n; i++) {
        if (arr[i] > max1) { max2 = max1; max1 = arr[i]; }
        else if (arr[i] > max2 && arr[i] != max1) max2 = arr[i];
    }
    cout << "Second Largest: " << max2 << endl;
    return 0;
}

Result-Second largest:34
