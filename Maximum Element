#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 5, 20, 8, 15};
    int n = 5;

    int maximum = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] > maximum) {
            maximum = arr[i];
        }
    }

    cout << "Largest element: " << maximum << endl;

    return 0;
}

Result-Largest element:20
